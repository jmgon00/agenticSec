// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id          String   @id @default(cuid())
  name        String
  email       String
  company     String?
  serviceType String // "vulnerability-analysis", "audit", "consulting", "ai-agents"
  message     String
  budgetRange String? // "5k-10k", "10k-25k", "25k+"
  status      String   @default("new") // "new", "contacted", "closed"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Consultation {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String
  company         String
  companySize     String // "startup", "pyme", "enterprise", "other"
  serviceInterest String // "web-analysis", "infrastructure", "compliance", "ia-inquiry", "other"
  message         String
  status          String   @default("pending") // "pending", "contacted", "completed"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Agent {
  id              String   @id @default(cuid())
  name            String   // "Agente Analizador de Vulnerabilidades"
  slug            String   @unique // "vuln-analyzer"
  description     String   // One-line description for gallery
  fullDescription String   // Longer description for detail page
  category        String   // "educativo" | "productivo"
  type            String   // "chat" | "form" | "link" | "scan" | "assessment"
  icon            String   // Emoji: "🔍", "📚", etc
  instructions    String?  // System prompt for Claude (optional for type="link")
  inputFormat     Json?    // Form field schema if type="form"
  maxTokens       Int?     // Optional for type="link"
  temperature     Float?   // Optional for type="link"
  externalUrl     String?  // URL for type="link" agents
  features        Json?    // Array of feature strings for type="link"
  active          Boolean  @default(true) // false = hidden from gallery and unreachable
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sessions        AgentSession[]

  @@index([slug])
  @@index([category])
}

model AgentSession {
  id              String   @id @default(cuid())
  userEmail       String   // User's email from localStorage
  agentId         String
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  title           String?  // Auto-generated from first message
  messages        Json     // Array of {role: "user"|"assistant", content, timestamp, tokens?}
  totalMessages   Int      @default(0)
  totalTokens     Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userEmail])
  @@index([agentId])
  @@index([createdAt])
}

model SecurityScanRun {
  id           String   @id @default(cuid())
  agentId      String
  userEmail    String
  target       String
  authorizedAt DateTime
  status       String   @default("running") // "running" | "completed" | "failed"
  findings     Json?
  summary      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([agentId])
  @@index([userEmail])
  @@index([createdAt])
}

model PersonalAssessmentRun {
  id        String   @id @default(cuid())
  agentId   String
  userEmail String
  answers   Json
  status    String   @default("running") // "running" | "completed" | "failed"
  findings  Json?
  summary   String?
  riskScore Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@index([userEmail])
  @@index([createdAt])
}
