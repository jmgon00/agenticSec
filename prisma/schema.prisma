// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id          String   @id @default(cuid())
  name        String
  email       String
  company     String?
  serviceType String // "vulnerability-analysis", "audit", "consulting", "ai-agents"
  message     String
  budgetRange String? // "5k-10k", "10k-25k", "25k+"
  status      String   @default("new") // "new", "contacted", "closed"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Consultation {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String
  company         String
  companySize     String // "startup", "pyme", "enterprise", "other"
  serviceInterest String // "web-analysis", "infrastructure", "compliance", "ia-inquiry", "other"
  message         String
  status          String   @default("pending") // "pending", "contacted", "completed"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}
